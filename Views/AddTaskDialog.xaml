<Window x:Class="M3U8Downloader.Views.AddTaskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:M3U8Downloader.Converters"
        xmlns:views="clr-namespace:M3U8Downloader.Views"
        Title="New Download Task"
        Width="550" Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border Background="#F5F5F5" CornerRadius="12" BorderBrush="#E0E0E0" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <views:CustomTitleBar Grid.Row="0" TitleText="New Download Task"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16">
                <StackPanel>
                    <!-- URL -->
                    <TextBlock Text="M3U8 URL" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <DockPanel>
                        <Button Content="Paste" Command="{Binding PasteUrlCommand}"
                                DockPanel.Dock="Right" Padding="12,4" Margin="8,0,0,0"
                                Background="#757575" Foreground="White" BorderThickness="0"
                                Cursor="Hand" FontSize="13"/>
                        <TextBox Text="{Binding M3u8Url, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13"/>
                    </DockPanel>

                    <!-- Parse button -->
                    <Button Content="Parse URL" Command="{Binding ParseCommand}"
                            Padding="16,6" Margin="0,8,0,0" HorizontalAlignment="Left"
                            Background="#2196F3" Foreground="White" BorderThickness="0"
                            Cursor="Hand" FontSize="13"/>

                    <!-- Parse Status -->
                    <TextBlock Text="{Binding ParseStatusText}" Margin="0,8,0,0"
                               FontSize="12" Foreground="#757575" TextWrapping="Wrap"/>

                    <!-- Variant Selection -->
                    <StackPanel Visibility="{Binding HasVariants, Converter={StaticResource BoolToVis}}"
                                Margin="0,12,0,0">
                        <TextBlock Text="Select Quality" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Variants}"
                                  SelectedIndex="{Binding SelectedVariantIndex}"
                                  DisplayMemberPath="DisplayName"
                                  Padding="8,4"/>
                    </StackPanel>

                    <!-- Segment Info -->
                    <TextBlock Text="{Binding SegmentInfoText}" FontSize="12" Foreground="#4CAF50"
                               Margin="0,8,0,0"/>

                    <Separator Margin="0,16,0,16"/>

                    <!-- File Name -->
                    <TextBlock Text="File Name (optional - auto-detected from URL if empty)"
                               FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding FileName, UpdateSourceTrigger=PropertyChanged}"
                             Padding="8,6"/>

                    <!-- Save Directory -->
                    <TextBlock Text="Save Directory (optional - uses default if empty)"
                               FontWeight="SemiBold" Margin="0,12,0,4"/>
                    <DockPanel>
                        <Button Content="Browse..." Command="{Binding BrowseDirCommand}"
                                DockPanel.Dock="Right" Padding="12,4" Margin="8,0,0,0"/>
                        <TextBox Text="{Binding SaveDirectory, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" VerticalContentAlignment="Center"/>
                    </DockPanel>

                    <Separator Margin="0,16,0,16"/>

                    <!-- Advanced HTTP Headers -->
                    <Expander Header="Advanced HTTP Headers" Margin="0,0,0,0">
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="User-Agent" FontSize="12" Foreground="#757575" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding CustomUserAgent}" Padding="6,4" Margin="0,0,0,8"/>

                            <TextBlock Text="Referer" FontSize="12" Foreground="#757575" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding CustomReferer}" Padding="6,4" Margin="0,0,0,8"/>

                            <TextBlock Text="Cookie" FontSize="12" Foreground="#757575" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding CustomCookies}" Padding="6,4"/>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <Border Grid.Row="2" Background="White" Padding="16,12"
                    BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Download" Command="{Binding DownloadCommand}"
                            Padding="24,8" Margin="0,0,8,0"
                            Background="#4CAF50" Foreground="White" BorderThickness="0"
                            Cursor="Hand" FontSize="13"/>
                    <Button Content="Cancel" Command="{Binding CancelCommand}"
                            Padding="24,8"
                            Background="#BDBDBD" Foreground="White" BorderThickness="0"
                            Cursor="Hand" FontSize="13"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
