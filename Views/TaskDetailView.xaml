<Window x:Class="M3U8Downloader.Views.TaskDetailView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:M3U8Downloader.Converters"
        xmlns:views="clr-namespace:M3U8Downloader.Views"
        Title="Task Detail"
        Width="800" Height="600"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">

    <Window.Resources>
        <conv:SegmentStatusToColorConverter x:Key="SegStatusColor"/>
        <conv:StatusToColorConverter x:Key="StatusToColor"/>
        <conv:StatusToTextConverter x:Key="StatusToText"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border Background="#F5F5F5" CornerRadius="12" BorderBrush="#E0E0E0" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <views:CustomTitleBar Grid.Row="0" TitleText="{Binding FileName}"/>

            <!-- Header -->
            <Border Grid.Row="1" Background="White" Padding="16,12"
                    BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- URL (selectable) -->
                    <TextBox Grid.Row="0" Text="{Binding SourceUrl, Mode=OneWay}" FontSize="11"
                             Foreground="#999999"
                             Margin="0,4,0,0" IsReadOnly="True" BorderThickness="0"
                             Background="Transparent" Padding="0"
                             TextWrapping="NoWrap"
                             Cursor="IBeam"/>

                    <!-- Progress -->
                    <Grid Grid.Row="1" Margin="0,12,0,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ProgressBar Grid.Row="0" Value="{Binding Progress}" Height="22"
                                     Background="#E0E0E0" Foreground="#2196F3"/>

                        <DockPanel Grid.Row="1" Margin="0,6,0,0">
                            <TextBlock DockPanel.Dock="Left" FontSize="13" Foreground="#333333">
                                <Run Text="{Binding Progress, StringFormat={}{0:F1}%, Mode=OneWay}" FontWeight="SemiBold"/>
                                <Run Text="  |  "/>
                                <Run Text="{Binding CompletedSegments, Mode=OneWay}"/>/<Run Text="{Binding TotalSegments, Mode=OneWay}"/>
                                <Run Text=" segments"/>
                                <Run Text="  |  "/>
                                <Run Text="{Binding SizeText, Mode=OneWay}"/>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                        DockPanel.Dock="Right">
                                <TextBlock Text="{Binding DownloadSpeedText, Mode=OneWay}"
                                           FontSize="13" Foreground="#4CAF50" Margin="0,0,12,0"/>
                                <TextBlock Text="{Binding RemainingTimeText, Mode=OneWay}"
                                           FontSize="13" Foreground="#757575"/>
                            </StackPanel>
                        </DockPanel>
                    </Grid>

                    <!-- Status + Buttons -->
                    <DockPanel Grid.Row="2" VerticalAlignment="Center">
                        <Border Background="{Binding Status, Converter={StaticResource StatusToColor}}"
                                CornerRadius="4" Padding="8,2" DockPanel.Dock="Left" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Status, Converter={StaticResource StatusToText}}"
                                       Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#757575"
                                   Margin="12,0,0,0" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                    DockPanel.Dock="Right" VerticalAlignment="Center">
                            <Button Content="{Binding PauseResumeButtonText}"
                                    Command="{Binding PauseResumeCommand}"
                                    Padding="16,6" Margin="0,0,8,0"
                                    Background="#FF9800" Foreground="White" BorderThickness="0"
                                    Cursor="Hand" FontSize="13"/>
                            <Button Content="Cancel" Command="{Binding CancelCommand}"
                                    Padding="16,6" Margin="0,0,8,0"
                                    Background="#F44336" Foreground="White" BorderThickness="0"
                                    Cursor="Hand" FontSize="13"/>
                            <Button Content="Retry" Command="{Binding RetryCommand}"
                                    Padding="16,6"
                                    Background="#2196F3" Foreground="White" BorderThickness="0"
                                    Cursor="Hand" FontSize="13"
                                    Visibility="{Binding CanRetry, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ErrorMessage}" FontSize="12" Foreground="#F44336"
                                   Margin="12,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Right"
                                   DockPanel.Dock="Right" TextTrimming="CharacterEllipsis"/>
                    </DockPanel>
                </Grid>
            </Border>

            <!-- Segment Grid -->
            <Grid Grid.Row="2" Margin="16,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Segment Status" FontSize="14" FontWeight="SemiBold"
                           Foreground="#333333" Margin="0,0,0,8"/>

                <!-- Legend -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                    <Border Width="12" Height="12" Background="#4CAF50" CornerRadius="2" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Completed" FontSize="11" Foreground="#757575" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <Border Width="12" Height="12" Background="#2196F3" CornerRadius="2" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Downloading" FontSize="11" Foreground="#757575" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <Border Width="12" Height="12" Background="#FF9800" CornerRadius="2" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Retrying" FontSize="11" Foreground="#757575" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <Border Width="12" Height="12" Background="#F44336" CornerRadius="2" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Failed (click to retry)" FontSize="11" Foreground="#757575" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <Border Width="12" Height="12" Background="#E0E0E0" CornerRadius="2" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Pending" FontSize="11" Foreground="#757575" VerticalAlignment="Center"/>
                    <Button Content="Retry All Failed" Command="{Binding RetryAllCommand}"
                            Padding="10,3" Margin="16,0,0,0" FontSize="11"
                            Background="#E3F2FD" Foreground="#1565C0"
                            BorderThickness="0" Cursor="Hand" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Segment Visualization (wrapped grid) -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Segments}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="8" Height="8" Margin="1"
                                        Background="{Binding Status, Converter={StaticResource SegStatusColor}}"
                                        CornerRadius="1" Cursor="Hand"
                                        ToolTip="{Binding Index, StringFormat=Segment #{0} (click to retry if failed)}">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.RetrySegmentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      CommandParameter="{Binding Index}"/>
                                    </Border.InputBindings>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
