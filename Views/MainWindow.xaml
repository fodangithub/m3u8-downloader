<Window x:Class="M3U8Downloader.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:M3U8Downloader.ViewModels"
        xmlns:models="clr-namespace:M3U8Downloader.Models"
        xmlns:conv="clr-namespace:M3U8Downloader.Converters"
        xmlns:views="clr-namespace:M3U8Downloader.Views"
        mc:Ignorable="d"
        Title="M3U8 Downloader"
        Width="900" Height="600"
        MinWidth="700" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">

    <Window.Resources>
        <conv:StatusToColorConverter x:Key="StatusToColor"/>
        <conv:StatusToTextConverter x:Key="StatusToText"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
    </Window.Resources>

    <Border Background="#0A0A12" CornerRadius="4" BorderBrush="#1E1E2E" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <views:CustomTitleBar Grid.Row="0" TitleText="M3U8 Downloader"/>

            <!-- Toolbar -->
            <Border Grid.Row="1" Background="#141420" Padding="12,8"
                    BorderBrush="#1E1E2E" BorderThickness="0,0,0,1">
                <DockPanel>
                    <TextBlock Text="M3U8_DOWNLOADER" FontSize="18" FontWeight="Bold"
                               VerticalAlignment="Center" Foreground="#00F0FF"
                               FontFamily="Consolas, 'Courier New'"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                        <Button Content="+ NEW_TASK" Command="{Binding AddTaskCommand}"
                                Padding="16,6" Margin="0,0,8,0"
                                Background="#1000F0FF" Foreground="#00F0FF" BorderBrush="#00F0FF"
                                BorderThickness="1" Cursor="Hand" FontSize="13"/>
                        <Button Content="SETTINGS" Command="{Binding OpenSettingsCommand}"
                                Padding="16,6" Margin="0,0,8,0"
                                Background="#10707088" Foreground="#707088" BorderBrush="#707088"
                                BorderThickness="1" Cursor="Hand" FontSize="13"/>
                        <Button Content="START_ALL" Command="{Binding StartAllCommand}"
                                Padding="16,6" Margin="0,0,8,0"
                                Background="#1000FF6A" Foreground="#00FF6A" BorderBrush="#00FF6A"
                                BorderThickness="1" Cursor="Hand" FontSize="13"/>
                        <Button Content="PAUSE_ALL" Command="{Binding PauseAllCommand}"
                                Padding="16,6"
                                Background="#10FFD000" Foreground="#FFD000" BorderBrush="#FFD000"
                                BorderThickness="1" Cursor="Hand" FontSize="13"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- FFmpeg Download Prompt -->
            <Border Grid.Row="2" Background="#1A1400" Padding="20"
                    Visibility="{Binding ShowFFmpegPrompt, Converter={StaticResource BoolToVis}}"
                    VerticalAlignment="Top" Margin="20,20,20,0"
                    CornerRadius="2" BorderBrush="#FFD000" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="// FFmpeg Not Found" FontSize="16" FontWeight="Bold"
                               Foreground="#FFD000" Margin="0,0,0,8"
                               FontFamily="Consolas, 'Courier New'"/>
                    <TextBlock Text="FFmpeg is required for merging and transcoding. Select a version and download:"
                               TextWrapping="Wrap" Foreground="#BBA000" Margin="0,0,0,8"
                               FontFamily="Consolas, 'Courier New'"/>
                    <ComboBox SelectedValue="{Binding SelectedFFmpegVersion}" Width="340"
                              HorizontalAlignment="Left" Padding="8,4"
                              SelectedValuePath="Tag" Margin="0,0,0,4">
                        <ComboBoxItem Content="FFmpeg 7.1 (Stable - Recommended)" Tag="stable_7_1"/>
                        <ComboBoxItem Content="FFmpeg 6.1 (LTS - Legacy GPU)" Tag="lts_6_1"/>
                        <ComboBoxItem Content="Latest Master (Bleeding Edge)" Tag="latest_master"/>
                    </ComboBox>
                    <TextBlock Text="{Binding FfmpegVersionDescription}"
                               TextWrapping="Wrap" Foreground="#997700" FontSize="11" Margin="0,0,0,12"
                               FontFamily="Consolas, 'Courier New'"/>
                    <Button Content="DOWNLOAD_FFMPEG" Command="{Binding DownloadFFmpegCommand}"
                            Padding="20,8" HorizontalAlignment="Left"
                            Background="#10FFD000" Foreground="#FFD000" BorderBrush="#FFD000"
                            BorderThickness="1" Cursor="Hand" FontSize="14"
                            Visibility="{Binding IsDownloadingFFmpeg, Converter={StaticResource InverseBoolToVis}}"/>
                    <StackPanel Visibility="{Binding IsDownloadingFFmpeg, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding FfmpegStatusText}" Foreground="#FFD000" Margin="0,0,0,4"
                                   FontFamily="Consolas, 'Courier New'"/>
                        <ProgressBar Value="{Binding FfmpegDownloadProgress}" Height="8"
                                     Background="#1A1A2E" Foreground="#FFD000"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Task List -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding ShowFFmpegPrompt, Converter={StaticResource InverseBoolToVis}}"
                          Margin="0,0,0,0">
                <ItemsControl ItemsSource="{Binding Tasks}" Margin="16,12">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="models:DownloadTask">
                            <Border Background="#141420" CornerRadius="2" Padding="16,12"
                                    Margin="0,0,0,8" BorderBrush="#1E1E2E" BorderThickness="1"
                                    Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftDoubleClick"
                                                  Command="{Binding DataContext.OpenTaskDetailCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header Row -->
                                    <DockPanel Grid.Row="0">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                                    DockPanel.Dock="Right">
                                            <Border Background="{Binding Status, Converter={StaticResource StatusToColor}}"
                                                    CornerRadius="2" Padding="8,2" Margin="8,0,0,0">
                                                <TextBlock Text="{Binding Status, Converter={StaticResource StatusToText}}"
                                                           Foreground="#0A0A12" FontSize="11" FontWeight="Bold"
                                                           FontFamily="Consolas, 'Courier New'"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding FileName}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="#E0E0F0" TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap"
                                                   FontFamily="Consolas, 'Courier New'"/>
                                    </DockPanel>

                                    <!-- Progress Bar -->
                                    <Grid Grid.Row="1" Margin="0,8,0,4">
                                        <ProgressBar Value="{Binding Progress, Mode=OneWay}"
                                                     Height="22" Background="#1A1A2E" Foreground="#00F0FF"/>
                                        <!-- Merge progress overlay -->
                                        <ProgressBar Value="{Binding MergeProgress, Mode=OneWay}"
                                                     Height="22" Background="Transparent" Foreground="#B400FF"
                                                     Visibility="{Binding IsMerging, Converter={StaticResource BoolToVis}}"/>
                                        <TextBlock Text="{Binding Progress, StringFormat={}{0:F3}%}"
                                                   HorizontalAlignment="Center" FontSize="11"
                                                   Foreground="#E0E0F0" VerticalAlignment="Center"
                                                   FontWeight="Bold"
                                                   Visibility="{Binding IsMerging, Converter={StaticResource InverseBoolToVis}}"
                                                   FontFamily="Consolas, 'Courier New'"/>
                                        <TextBlock Text="{Binding MergeProgress, StringFormat={}{0:F1}% MERGING}"
                                                   HorizontalAlignment="Center" FontSize="11"
                                                   Foreground="#E0E0F0" VerticalAlignment="Center"
                                                   FontWeight="Bold"
                                                   Visibility="{Binding IsMerging, Converter={StaticResource BoolToVis}}"
                                                   FontFamily="Consolas, 'Courier New'"/>
                                    </Grid>

                                    <!-- Info Row -->
                                    <DockPanel Grid.Row="2">
                                        <TextBlock DockPanel.Dock="Left" FontSize="12" Foreground="#707088"
                                                   FontFamily="Consolas, 'Courier New'">
                                            <Run Text="{Binding CompletedSegments, Mode=OneWay}"/>/<Run Text="{Binding TotalSegments, Mode=OneWay}"/>
                                            <Run Text=" segments"/>
                                            <Run Text=" | "/>
                                            <Run Text="{Binding SizeText, Mode=OneWay}"/>
                                            <Run Text=" | "/>
                                            <Run Text="{Binding DownloadSpeedText, Mode=OneWay}"/>
                                            <Run Text="{Binding RemainingTimeText, Mode=OneWay}"/>
                                        </TextBlock>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                                    DockPanel.Dock="Right">
                                            <Button Content="VIEW" Command="{Binding DataContext.OpenTaskDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="10,3" Margin="4,0,0,0"
                                                    FontSize="11" Background="#1000F0FF" Foreground="#00F0FF"
                                                    BorderBrush="#00F0FF" BorderThickness="1" Cursor="Hand"/>
                                            <Button Content="FOLDER" Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="10,3" Margin="4,0,0,0"
                                                    FontSize="11" Background="#1000FF6A" Foreground="#00FF6A"
                                                    BorderBrush="#00FF6A" BorderThickness="1" Cursor="Hand"/>
                                            <!-- Retry button for Failed/Cancelled tasks -->
                                            <Button Content="RETRY"
                                                    Command="{Binding DataContext.RetryTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="10,3" Margin="4,0,0,0"
                                                    FontSize="11" Background="#1000F0FF" Foreground="#00F0FF"
                                                    BorderBrush="#00F0FF" BorderThickness="1" Cursor="Hand"
                                                    Visibility="{Binding IsFailedOrCancelled, Converter={StaticResource BoolToVis}}"/>
                                            <!-- Pause/Resume button for active tasks -->
                                            <Button
                                                    Command="{Binding DataContext.PauseTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="10,3" Margin="4,0,0,0"
                                                    FontSize="11" Background="#10FFD000" Foreground="#FFD000"
                                                    BorderBrush="#FFD000" BorderThickness="1" Cursor="Hand"
                                                    Visibility="{Binding IsActiveOrPaused, Converter={StaticResource BoolToVis}}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Content" Value="PAUSE"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                                <Setter Property="Content" Value="RESUME"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </DockPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty State -->
            <TextBlock Grid.Row="2"
                       Text="// No download tasks. Click '+ NEW_TASK' to add one."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="14" Foreground="#707088"
                       FontFamily="Consolas, 'Courier New'">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Tasks.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Status Bar -->
            <Border Grid.Row="3" Background="#141420" Padding="12,6"
                    BorderBrush="#1E1E2E" BorderThickness="0,1,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" FontSize="12" Foreground="#707088"
                               FontFamily="Consolas, 'Courier New'">
                        <Run Text="TASKS: "/><Run Text="{Binding Tasks.Count, Mode=OneWay}"/>
                        <Run Text=" | ACTIVE: "/><Run Text="{Binding ActiveTaskCount, Mode=OneWay}"/>
                        <Run Text=" | DONE: "/><Run Text="{Binding CompletedTaskCount, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                               FontSize="12" Foreground="#00F0FF"
                               FontFamily="Consolas, 'Courier New'"
                               Text="{Binding TotalSpeedText, StringFormat=SPEED: {0}}"/>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
