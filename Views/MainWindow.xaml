<Window x:Class="M3U8Downloader.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:M3U8Downloader.ViewModels"
        xmlns:models="clr-namespace:M3U8Downloader.Models"
        xmlns:conv="clr-namespace:M3U8Downloader.Converters"
        xmlns:views="clr-namespace:M3U8Downloader.Views"
        mc:Ignorable="d"
        Title="M3U8 Downloader"
        Width="900" Height="600"
        MinWidth="700" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">

    <Window.Resources>
        <conv:StatusToColorConverter x:Key="StatusToColor"/>
        <conv:StatusToTextConverter x:Key="StatusToText"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
    </Window.Resources>

    <Border Background="#F5F5F5" CornerRadius="12" BorderBrush="#E0E0E0" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <views:CustomTitleBar Grid.Row="0" TitleText="M3U8 Downloader"/>

            <!-- Toolbar -->
            <Border Grid.Row="1" Background="#FFFFFF" Padding="12,8"
                    BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                <DockPanel>
                    <TextBlock Text="M3U8 Downloader" FontSize="18" FontWeight="SemiBold"
                               VerticalAlignment="Center" Foreground="#333333"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                        <Button Content="+ New Task" Command="{Binding AddTaskCommand}"
                                Padding="16,6" Margin="0,0,8,0"
                                Background="#2196F3" Foreground="White" BorderThickness="0"
                                Cursor="Hand" FontSize="13"/>
                        <Button Content="Settings" Command="{Binding OpenSettingsCommand}"
                                Padding="16,6" Margin="0,0,8,0"
                                Background="#757575" Foreground="White" BorderThickness="0"
                                Cursor="Hand" FontSize="13"/>
                        <Button Content="Start All" Command="{Binding StartAllCommand}"
                                Padding="16,6" Margin="0,0,8,0"
                                Background="#4CAF50" Foreground="White" BorderThickness="0"
                                Cursor="Hand" FontSize="13"/>
                        <Button Content="Pause All" Command="{Binding PauseAllCommand}"
                                Padding="16,6"
                                Background="#FF9800" Foreground="White" BorderThickness="0"
                                Cursor="Hand" FontSize="13"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- FFmpeg Download Prompt -->
            <Border Grid.Row="2" Background="#FFF3E0" Padding="20"
                    Visibility="{Binding ShowFFmpegPrompt, Converter={StaticResource BoolToVis}}"
                    VerticalAlignment="Top" Margin="20,20,20,0"
                    CornerRadius="8" BorderBrush="#FFB74D" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="FFmpeg Not Found" FontSize="16" FontWeight="SemiBold"
                               Foreground="#E65100" Margin="0,0,0,8"/>
                    <TextBlock Text="FFmpeg is required for merging and transcoding. Click below to download automatically."
                               TextWrapping="Wrap" Foreground="#BF360C" Margin="0,0,0,12"/>
                    <Button Content="Download FFmpeg" Command="{Binding DownloadFFmpegCommand}"
                            Padding="20,8" HorizontalAlignment="Left"
                            Background="#FF6D00" Foreground="White" BorderThickness="0"
                            Cursor="Hand" FontSize="14"
                            Visibility="{Binding IsDownloadingFFmpeg, Converter={StaticResource InverseBoolToVis}}"/>
                    <StackPanel Visibility="{Binding IsDownloadingFFmpeg, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding FfmpegStatusText}" Foreground="#E65100" Margin="0,0,0,4"/>
                        <ProgressBar Value="{Binding FfmpegDownloadProgress}" Height="8"
                                     Background="#FFE0B2" Foreground="#FF6D00"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Task List -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding ShowFFmpegPrompt, Converter={StaticResource InverseBoolToVis}}"
                          Margin="0,0,0,0">
                <ItemsControl ItemsSource="{Binding Tasks}" Margin="16,12">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="models:DownloadTask">
                            <Border Background="White" CornerRadius="8" Padding="16,12"
                                    Margin="0,0,0,8" BorderBrush="#E0E0E0" BorderThickness="1"
                                    Cursor="Hand">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftDoubleClick"
                                                  Command="{Binding DataContext.OpenTaskDetailCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header Row -->
                                    <DockPanel Grid.Row="0">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                                    DockPanel.Dock="Right">
                                            <Border Background="{Binding Status, Converter={StaticResource StatusToColor}}"
                                                    CornerRadius="4" Padding="8,2" Margin="8,0,0,0">
                                                <TextBlock Text="{Binding Status, Converter={StaticResource StatusToText}}"
                                                           Foreground="White" FontSize="11"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding FileName}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="#333333" TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap"/>
                                    </DockPanel>

                                    <!-- Progress Bar -->
                                    <Grid Grid.Row="1" Margin="0,8,0,4">
                                        <ProgressBar Value="{Binding Progress, Mode=OneWay}"
                                                     Height="22" Background="#E0E0E0" Foreground="#2196F3"/>
                                        <!-- Merge progress overlay - purple -->
                                        <ProgressBar Value="{Binding MergeProgress, Mode=OneWay}"
                                                     Height="22" Background="Transparent" Foreground="#9C27B0"
                                                     Visibility="{Binding IsMerging, Converter={StaticResource BoolToVis}}"/>
                                        <TextBlock Text="{Binding Progress, StringFormat={}{0:F3}%}"
                                                   HorizontalAlignment="Center" FontSize="11"
                                                   Foreground="White" VerticalAlignment="Center"
                                                   Visibility="{Binding IsMerging, Converter={StaticResource InverseBoolToVis}}"/>
                                        <TextBlock Text="{Binding MergeProgress, StringFormat={}{0:F1}% Merging}"
                                                   HorizontalAlignment="Center" FontSize="11"
                                                   Foreground="White" VerticalAlignment="Center"
                                                   Visibility="{Binding IsMerging, Converter={StaticResource BoolToVis}}"/>
                                    </Grid>

                                    <!-- Info Row -->
                                    <DockPanel Grid.Row="2">
                                        <TextBlock DockPanel.Dock="Left" FontSize="12" Foreground="#999999">
                                            <Run Text="{Binding CompletedSegments, Mode=OneWay}"/>/<Run Text="{Binding TotalSegments, Mode=OneWay}"/>
                                            <Run Text=" segments"/>
                                            <Run Text=" | "/>
                                            <Run Text="{Binding SizeText, Mode=OneWay}"/>
                                            <Run Text=" | "/>
                                            <Run Text="{Binding DownloadSpeedText, Mode=OneWay}"/>
                                            <Run Text="{Binding RemainingTimeText, Mode=OneWay}"/>
                                        </TextBlock>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                                    DockPanel.Dock="Right">
                                            <Button Content="View" Command="{Binding DataContext.OpenTaskDetailCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="10,3" Margin="4,0,0,0"
                                                    FontSize="11" Background="#E3F2FD" Foreground="#1565C0"
                                                    BorderThickness="0" Cursor="Hand"/>
                                            <Button Content="Folder" Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="10,3" Margin="4,0,0,0"
                                                    FontSize="11" Background="#E8F5E9" Foreground="#2E7D32"
                                                    BorderThickness="0" Cursor="Hand"/>
                                            <!-- Retry button for Failed/Cancelled tasks -->
                                            <Button Content="Retry"
                                                    Command="{Binding DataContext.RetryTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="10,3" Margin="4,0,0,0"
                                                    FontSize="11" Background="#E3F2FD" Foreground="#1565C0"
                                                    BorderThickness="0" Cursor="Hand"
                                                    Visibility="{Binding IsFailedOrCancelled, Converter={StaticResource BoolToVis}}"/>
                                            <!-- Pause/Resume button for active tasks -->
                                            <Button
                                                    Command="{Binding DataContext.PauseTaskCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="10,3" Margin="4,0,0,0"
                                                    FontSize="11" Background="#FFF3E0" Foreground="#E65100"
                                                    BorderThickness="0" Cursor="Hand"
                                                    Visibility="{Binding IsActiveOrPaused, Converter={StaticResource BoolToVis}}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Content" Value="Pause"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                                <Setter Property="Content" Value="Resume"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </DockPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty State -->
            <TextBlock Grid.Row="2"
                       Text="No download tasks. Click '+ New Task' to add one."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="14" Foreground="#BDBDBD"
                       Visibility="{Binding Tasks.Count, Converter={StaticResource BoolToVis}, ConverterParameter=inverse, FallbackValue=Visible}"/>

            <!-- Status Bar -->
            <Border Grid.Row="3" Background="#FFFFFF" Padding="12,6"
                    BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Left" FontSize="12" Foreground="#757575">
                        <Run Text="Tasks: "/><Run Text="{Binding Tasks.Count, Mode=OneWay}"/>
                        <Run Text=" | Active: "/><Run Text="{Binding ActiveTaskCount, Mode=OneWay}"/>
                        <Run Text=" | Completed: "/><Run Text="{Binding CompletedTaskCount, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                               FontSize="12" Foreground="#757575"
                               Text="{Binding TotalSpeedText, StringFormat=Total Speed: {0}}"/>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
