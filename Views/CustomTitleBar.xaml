<UserControl x:Class="M3U8Downloader.Views.CustomTitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MouseLeftButtonDown="OnTitleBarMouseDown">
    <Border Background="{StaticResource TitleBarGradient}" Padding="12,0"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
            CornerRadius="4,4,0,0">
        <DockPanel Height="40">
            <!-- Window buttons -->
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                <!-- Minimize button -->
                <Button Width="46" Height="32" ToolTip="Minimize"
                        Click="OnMinimizeClick" Cursor="Hand"
                        Background="Transparent" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="{TemplateBinding Background}"
                                    Width="{TemplateBinding Width}"
                                    Height="{TemplateBinding Height}">
                                <Path Data="M 2 8 L 14 8" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                    <Setter TargetName="bg" Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="{DynamicResource PrimaryBrush}" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <!-- Close button -->
                <Button Width="46" Height="32" ToolTip="Close"
                        Click="OnCloseClick" Cursor="Hand"
                        Background="Transparent" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="{TemplateBinding Background}"
                                    Width="{TemplateBinding Width}"
                                    Height="{TemplateBinding Height}">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path x:Name="icon" Data="M 1 1 L 11 11 M 11 1 L 1 11"
                                          Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="1.2"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                    <Setter TargetName="icon" Property="Stroke" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
            <!-- Title -->
            <TextBlock Text="{Binding TitleText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontSize="13" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                       FontFamily="Consolas, 'Courier New'"/>
        </DockPanel>
    </Border>
</UserControl>
